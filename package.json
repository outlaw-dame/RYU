{
  "name": "ryu",
  "private": true,
  "version": "0.2.0",
  "type": "module",
  "description": "A local-first iOS-style Progressive Web App client for BookWyrm.",
  "license": "AGPL-3.0-or-later",
  "repository": {
    "type": "git",
    "url": "https://github.com/outlaw-dame/RYU.git"
  },
  "keywords": [
    "bookwyrm",
    "activitypub",
    "pwa",
    "ios",
    "local-first",
    "rxdb",
    "indexeddb",
    "books"
  ],
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:ui:smoke": "vitest run src/app/App.search-a11y.test.tsx",
    "test:e2e": "playwright test",
    "test:e2e:headed": "playwright test --headed",
    "auth:contracts": "tsx scripts/auth-contract-harness.ts",
    "auth:smoke": "tsx scripts/auth-backend-smoke.ts",
    "auth:server": "tsx server/start-mastodon-auth-server.ts",
    "schema:eval": "tsx scripts/schema-eval.ts",
    "db:schema-smoke": "tsx scripts/rxdb-authorids-smoke.ts",
    "activitypub:indexing-eval": "tsx scripts/activitypub-dependency-indexing-eval.ts",
    "activitypub:enrichment-eval": "tsx scripts/activitypub-enrichment-isolation-eval.ts",
    "search:eval": "tsx scripts/search-eval.ts",
    "search:indexing-eval": "tsx scripts/write-through-indexing-eval.ts",
    "search:health-eval": "tsx scripts/search-index-health-eval.ts",
    "search:db-scope-eval": "tsx scripts/db-scoped-vector-indexing-eval.ts",
    "clean": "rm -rf dist .vite node_modules/.vite"
  },
  "overrides": {
    "ajv": "^8.18.0"
  },
  "dependencies": {
    "@huggingface/transformers": "^3.7.2",
    "@litertjs/core": "^0.1.0",
    "@mlc-ai/web-llm": "^0.2.79",
    "@orama/orama": "^2.0.0",
    "@tanstack/react-query": "^5.62.7",
    "dexie": "^4.0.10",
    "dompurify": "^3.2.3",
    "framer-motion": "^12.0.0",
    "lucide-react": "^0.468.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "rxdb": "^16.19.0",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@playwright/test": "^1.53.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.3.4",
    "jsdom": "^29.1.0",
    "fake-indexeddb": "^6.2.5",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vite": "^6.0.0",
    "vitest": "^4.1.5"
  }
}
